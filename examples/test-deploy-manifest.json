{
  "namespace": "test",
  "services": [
    {
      "name": "whoami",
      "placement": {
        "replicated": {
          "count": 3
        }
      },
      "template": {
        "image": "traefik/whoami:latest",
        "env": {
          "WHOAMI_PORT_NUMBER": "8080",
          "PLOYZ_REVISION_BUMP": "2",
          "PLOYZ_DNS_DEFAULT_TEST": "1"
        }
      },
      "network": "overlay",
      "service_ports": [
        {
          "name": "http",
          "container_port": 8080,
          "protocol": "tcp"
        }
      ],
      "readiness": {
        "http": {
          "service_port": "http",
          "path": "/"
        },
        "start_period": "10s"
      },
      "publish": [
        {
          "service_port": "http",
          "host_port": 9090
        }
      ],
      "routes": [
        {
          "http": {
            "service_port": "http",
            "hostnames": [
              "localhost"
            ],
            "path_prefix": "/"
          }
        }
      ],
      "restart": "unless-stopped"
    },
    {
      "name": "toolbox",
      "placement": {
        "replicated": {
          "count": 1
        }
      },
      "template": {
        "image": "busybox:1.36",
        "command": [
          "sh",
          "-lc",
          "while true; do sleep 3600; done"
        ]
      },
      "network": "overlay",
      "restart": "unless-stopped"
    }
  ]
}
